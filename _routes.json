{
  "version": 1,
  "include": ["/*"],
  "exclude": [],
  "routes": [
    { "src": "/_next/static/.*", "dest": "/_next/static/$0", "headers": { "cache-control": "public, max-age=31536000, immutable" } },
    { "src": "/favicon.ico", "dest": "/favicon.ico", "headers": { "cache-control": "public, max-age=86400" } },
    { "src": "/sw.js", "dest": "/sw.js", "headers": { "cache-control": "public, max-age=86400" } }
  ]
}
